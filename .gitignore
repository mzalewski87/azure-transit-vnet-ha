# =============================================================================
# Terraform - Azure Transit VNet / VM-Series HA
# =============================================================================

# Local variable values - NEVER commit this file (contains sensitive data)
terraform.tfvars

# Terraform state files - contain real infrastructure details
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform working directory
.terraform/

# .terraform.lock.hcl is intentionally NOT ignored — it pins provider versions
# and should be committed for reproducible builds (Terraform best practice).

# Crash logs
crash.log
crash.*.log

# Runtime logs (terraform destroy/apply output)
*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan output (may contain sensitive values)
*.tfplan
tfplan

# Variable files with secrets (use terraform.tfvars.example as template)
*.auto.tfvars
secrets.tfvars
sensitive.tfvars

# Bootstrap rendered files (generated by Terraform local_file with init-cfg)
modules/bootstrap/rendered/

# Generated auth key files
panorama_vm_auth_key.txt

# Editor / OS
.DS_Store
*.textClipping
*.swp
*.swo
.idea/
.vscode/settings.json

# Defensive: certificate / key material and env files (none used today,
# guard against accidental future commits)
*.pem
*.key
*.crt
*.pfx
.env
.env.*

# Reference PDF library — vendor-copyrighted documents (PANW, etc.)
# Track only the catalogue / index, not the binaries.
docs/reference/pdfs/*.pdf
