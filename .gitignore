# =============================================================================
# Terraform - Azure Transit VNet / VM-Series HA
# =============================================================================

# Local variable values - NEVER commit this file (contains sensitive data)
terraform.tfvars

# Terraform state files - contain real infrastructure details
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan output (may contain sensitive values)
*.tfplan
tfplan

# Variable files with secrets (use terraform.tfvars.example as template)
*.auto.tfvars
secrets.tfvars
sensitive.tfvars

# Editor / OS
.DS_Store
*.swp
*.swo
.idea/
.vscode/settings.json
