###############################################################################
# terraform.tfvars.example
# Copy to terraform.tfvars and fill in REPLACE_ME values
#
#   cp terraform.tfvars.example terraform.tfvars
#   nano terraform.tfvars
###############################################################################

#------------------------------------------------------------------------------
# Azure Subscriptions
# For demo single-subscription: use the same subscription in each field
# az account show --query id -o tsv
#------------------------------------------------------------------------------
hub_subscription_id    = "REPLACE_ME_HUB_SUBSCRIPTION_ID"
spoke1_subscription_id = "REPLACE_ME_SPOKE1_SUBSCRIPTION_ID"
spoke2_subscription_id = "REPLACE_ME_SPOKE2_SUBSCRIPTION_ID"

#------------------------------------------------------------------------------
# Location and Resource Groups
#------------------------------------------------------------------------------
location = "germanywestcentral"

hub_resource_group_name  = "rg-transit-hub"
app1_resource_group_name = "rg-app1"
app2_resource_group_name = "rg-app2-dc"

#------------------------------------------------------------------------------
# VNet Address Spaces (PANW reference architecture)
#------------------------------------------------------------------------------
management_vnet_address_space = "10.255.0.0/16"
transit_vnet_address_space    = "10.110.0.0/16"
app1_vnet_address_space       = "10.112.0.0/16"
app2_vnet_address_space       = "10.113.0.0/16"

# internal_lb_private_ip – DO NOT SET (auto-computed from transit CIDR)
# Terraform computes automatically: cidrhost(cidrsubnet(transit_vnet_address_space, 8, 0), 21)
# Example: transit=10.110.0.0/16 → snet-private=10.110.0.0/24 → ILB=10.110.0.21
# Set ONLY if you want to override (must be in snet-private!)
# internal_lb_private_ip = ""

#------------------------------------------------------------------------------
# VM-Series Firewall + Panorama — passwords and sizes
#------------------------------------------------------------------------------
fw_vm_size     = "Standard_D8s_v3"   # 8 vCPU (required), 32 GB
pan_os_version = "latest"

panorama_vm_size = "Standard_D16s_v3"  # 16 vCPU, 64 GB

admin_username = "panadmin"
# Min 12 chars, uppercase+lowercase+digit+special
admin_password = "REPLACE_ME_Admin@Password1!"

#------------------------------------------------------------------------------
# Panorama — data from CSP Portal (support.paloaltonetworks.com)
#
# ORDER:
#   panorama_serial_number → phase2-panorama-config/terraform.tfvars (Phase 2a)
#   panorama_vm_auth_key   → AUTO-GENERATED by Phase 2a Step 4, written to
#                            ../panorama_vm_auth_key.auto.tfvars and auto-loaded
#                            by Phase 1b. Leave empty here unless you have a
#                            pre-existing key to override.
#------------------------------------------------------------------------------
panorama_private_ip    = "10.255.0.4"

panorama_log_disk_size_gb = 2048   # 2TB Premium SSD

# Panorama Template Stack + Device Group (must match the names used in
# modules/panorama_config so the FW init-cfg references existing objects
# after Phase 2a creates them).
panorama_template_stack = "Transit-VNet-Stack"
panorama_device_group   = "Transit-VNet-DG"

# VM Auth Key — leave empty. Phase 2a Step 4 generates it via
# `request authkey add lifetime 168 count 2` on Panorama, writes to
# ../panorama_vm_auth_key.auto.tfvars (Terraform auto-loads *.auto.tfvars),
# and Phase 1b consumes it from that file when bootstrapping the FWs.
# Set explicitly only if importing a key from another deploy.
panorama_vm_auth_key = ""   # Format: 2:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

#------------------------------------------------------------------------------
# VM-Series FW License
# CSP Portal → Assets → Auth Codes → VM-Series BYOL
#------------------------------------------------------------------------------
fw_auth_code = ""   # Format: XXXXXXXX (8 alphanumeric chars)

#------------------------------------------------------------------------------
# VM-Series Auto-Registration PIN (for FW device certificates)
#
# CSP Portal → Assets → Device Certificates → Generate Registration PIN
# Save the PIN ID and PIN Value pair. ONE pair works for BOTH FWs (PINs are
# per-CSP-account, NOT per-serial — unlike OTPs, which require a known
# serial up-front, which VM-Series BYOL FWs don't have until they boot).
#
# Used at FW first boot only. The bootstrap module emits these as
# vm-series-auto-registration-pin-id= and vm-series-auto-registration-pin-value=
# in init-cfg.txt. The FW then auto-registers and fetches its device cert
# during license activation — no post-boot fetch step needed.
#
# Empty = skip auto-fetch (FW boots without device cert; fine for lab).
# Choose the shortest expiration in CSP Portal that fits your deploy window.
#
# Note: Panorama uses a DIFFERENT mechanism (per-serial OTP) because its
# serial IS known up-front (panorama_serial_number var). See
# phase2-panorama-config/terraform.tfvars.example for panorama_device_otp.
#
# Ref: VM-Series Deployment Guide v11.1, pages 178-181.
#------------------------------------------------------------------------------
fw_registration_pin_id    = ""   # PIN ID from CSP Portal Generate Registration PIN
fw_registration_pin_value = ""   # Matching PIN Value

#------------------------------------------------------------------------------
# Windows Domain Controller
#------------------------------------------------------------------------------
dc_admin_username    = "dcadmin"
dc_admin_password    = "REPLACE_ME_DcAdmin@Password1!"
dc_vm_size           = "Standard_B2s_v2"
dc_domain_name       = "panw.labs"
dc_skip_auto_promote = false   # true = skip automatic DC promotion

#------------------------------------------------------------------------------
# Azure Front Door
#------------------------------------------------------------------------------
frontdoor_sku = "Premium_AzureFrontDoor"

#------------------------------------------------------------------------------
# Tags
#------------------------------------------------------------------------------
tags = {
  Environment = "Demo"
  Project     = "PAN-Transit-VNet-HA"
  ManagedBy   = "Terraform"
  Owner       = "REPLACE_ME_YOUR_NAME"
  CostCenter  = "IT-Security"
}
