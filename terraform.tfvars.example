###############################################################################
# terraform.tfvars.example
# Skopiuj do terraform.tfvars i uzupełnij wartości REPLACE_ME
#
#   cp terraform.tfvars.example terraform.tfvars
#   nano terraform.tfvars
###############################################################################

#------------------------------------------------------------------------------
# Subskrypcje Azure
# Dla demo single-subscription: wstaw tę samą subskrypcję w każdym polu
# az account show --query id -o tsv
#------------------------------------------------------------------------------
hub_subscription_id    = "REPLACE_ME_HUB_SUBSCRIPTION_ID"
spoke1_subscription_id = "REPLACE_ME_SPOKE1_SUBSCRIPTION_ID"
spoke2_subscription_id = "REPLACE_ME_SPOKE2_SUBSCRIPTION_ID"

#------------------------------------------------------------------------------
# Lokalizacja i Resource Groups
#------------------------------------------------------------------------------
location = "germanywestcentral"

hub_resource_group_name  = "rg-transit-hub"
app1_resource_group_name = "rg-app1"
app2_resource_group_name = "rg-app2-dc"

#------------------------------------------------------------------------------
# VNet Address Spaces (architektura referencyjna PANW)
#------------------------------------------------------------------------------
management_vnet_address_space = "10.255.0.0/16"
transit_vnet_address_space    = "10.110.0.0/16"
app1_vnet_address_space       = "10.112.0.0/16"
app2_vnet_address_space       = "10.113.0.0/16"

# Internal LB IP (musi być w snet-private 10.110.0.0/24)
internal_lb_private_ip = "10.110.0.21"

#------------------------------------------------------------------------------
# VM-Series Firewall + Panorama – hasła i rozmiary
#------------------------------------------------------------------------------
fw_vm_size     = "Standard_D8s_v3"   # 8 vCPU (wymagane przez zadanie), 32 GB
pan_os_version = "latest"

panorama_vm_size = "Standard_D16s_v3"  # 16 vCPU, 64 GB

admin_username = "panadmin"
# Min 12 znaków, uppercase+lowercase+digit+special
admin_password = "REPLACE_ME_Admin@Password1!"

#------------------------------------------------------------------------------
# Panorama – dane z CSP Portal (support.paloaltonetworks.com)
#
# KOLEJNOŚĆ: panorama_serial_number + panorama_auth_code → KROK 1a
#            panorama_vm_auth_key → po aktywacji licencji Panoramy → KROK 1b
#------------------------------------------------------------------------------
panorama_private_ip    = "10.255.0.4"
panorama_hostname      = "panorama-transit-hub"

# CSP Portal → Assets → Devices → wybierz Panorama → Serial Number
panorama_serial_number = ""   # Format: 007300XXXXXXX

# CSP Portal → Assets → Auth Codes → Panorama BYOL
panorama_auth_code = ""   # Format: XXXX-XXXX-XXXX-XXXX

panorama_log_disk_size_gb = 2048   # 2TB Premium SSD

# Panorama Template Stack + Device Group (muszą istnieć zanim wdrożysz FW)
panorama_template_stack = "Transit-VNet-Stack"
panorama_device_group   = "Transit-VNet-DG"

# VM Auth Key – generuj po aktywacji licencji Panoramy:
#   az network bastion ssh --name bastion-management \
#     --resource-group rg-transit-hub \
#     --target-ip-address 10.255.0.4 \
#     --auth-type password --username panadmin
#   admin@panorama> request vm-auth-key generate lifetime 168
panorama_vm_auth_key = ""   # Format: 2:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

#------------------------------------------------------------------------------
# VM-Series FW Licencja
# CSP Portal → Assets → Auth Codes → VM-Series BYOL
#------------------------------------------------------------------------------
fw_auth_code = ""   # Format: XXXX-XXXX-XXXX-XXXX

#------------------------------------------------------------------------------
# Windows Domain Controller
#------------------------------------------------------------------------------
dc_admin_username    = "dcadmin"
dc_admin_password    = "REPLACE_ME_DcAdmin@Password1!"
dc_vm_size           = "Standard_B2ms"
dc_domain_name       = "panw.labs"
dc_skip_auto_promote = false   # true = pomiń automatyczną promocję DC

#------------------------------------------------------------------------------
# Azure Front Door
#------------------------------------------------------------------------------
frontdoor_sku = "Premium_AzureFrontDoor"

#------------------------------------------------------------------------------
# Bootstrap SA – dostęp z maszyny Terraform operatora
# Azure Policy wymaga ograniczenia dostępu do SA (network_rules.default_action = Deny)
# Pobierz swój IP: curl -s https://api.ipify.org
#------------------------------------------------------------------------------
terraform_operator_ips = ["REPLACE_ME_YOUR_PUBLIC_IP"]  # np. ["203.0.113.10"]

#------------------------------------------------------------------------------
# Tags
#------------------------------------------------------------------------------
tags = {
  Environment = "Demo"
  Project     = "PAN-Transit-VNet-HA"
  ManagedBy   = "Terraform"
  Owner       = "REPLACE_ME_YOUR_NAME"
  CostCenter  = "IT-Security"
}
