###############################################################################
# Phase 2 – terraform.tfvars.example
# Panorama Configuration via API + panos provider
#
#   cp terraform.tfvars.example terraform.tfvars
#
# BEFORE DEPLOYMENT:
#   1. Phase 1a completed (Panorama VM running)
#   2. Bastion tunnel in separate terminal:
#        PANORAMA_ID=$(cd .. && terraform output -raw panorama_vm_id)
#        az network bastion tunnel \
#          --name bastion-management --resource-group rg-transit-hub \
#          --target-resource-id "$PANORAMA_ID" \
#          --resource-port 443 --port 44300
#   3. terraform init && terraform apply
###############################################################################

# Panorama connection (Bastion tunnel)
panorama_hostname = "127.0.0.1"
panorama_port     = 44300
panorama_username = "panadmin"
panorama_password = "REPLACE_ME_Admin@Password1!"

# Hostname configured on Panorama
panorama_target_hostname = "panorama-transit-hub"

# Serial number from CSP Portal (my.paloaltonetworks.com -> Assets -> Add Product)
# Empty = skip license activation
panorama_serial_number = ""   # e.g. "007300202012345"

# OTP for Panorama device certificate (CSP Portal -> Assets -> Device Certificates ->
# Generate OTP for Panorama serial). 60-min lifetime, single-use.
# Empty = skip device-cert fetch (Panorama works without one for on-prem logs).
panorama_device_otp = ""      # e.g. "abc123def456..."

# vm-auth-key lifetime in minutes (1440 = 24h, max 8760 = 365 days)
vm_auth_key_lifetime = 1440

# Template & Device Group (must match Phase 1 bootstrap init-cfg)
template_name       = "Transit-VNet-Template"
template_stack_name = "Transit-VNet-Stack"
device_group_name   = "Transit-VNet-DG"

# Network CIDRs — default values match reference architecture
# Change ONLY if you modified VNet CIDRs in Phase 1
trust_subnet_cidr   = "10.110.0.0/24"
untrust_subnet_cidr = "10.110.129.0/24"
spoke1_vnet_cidr    = "10.112.0.0/16"
spoke2_vnet_cidr    = "10.113.0.0/16"

# Endpoints
apache_server_ip      = "10.112.0.4"
external_lb_public_ip = "REPLACE_ME"  # cd .. && terraform output external_lb_public_ip
